cat > .gitignore << 'EOF'
# ======= SECRETOS Y CREDENCIALES =======
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_ed25519
*_rsa
*_ed25519
.env
.env.*
!.env.example        # sí subir la plantilla sin valores

# Ansible
ansible/vault_password
ansible/group_vars/*/vault.yml
ansible/*.vault
inventory/passwords*

# Terraform / OpenTofu
*.tfvars
!*.tfvars.example    # sí subir la plantilla
.terraform/
terraform.tfstate
terraform.tfstate.backup
.terraform.lock.hcl  # opcional, muchos sí lo suben

# Ceph
ceph/ceph.conf       # si contiene IPs/tokens sensibles
ceph/keyring
*.keyring

# Kubernetes / Incus / OVN
kubeconfig
**/secrets/
**/secret.yaml
**/secret.yml

# Monitoring
grafana/grafana.ini   # si contiene passwords
prometheus/web-config.yml

# Base de datos
**/*password*
**/*credentials*
pg_hba.conf

# Sistema
.DS_Store
__pycache__/
*.pyc
*.log
*.tmp
EOF
